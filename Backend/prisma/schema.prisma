// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Users {
  id Int @id @default(autoincrement())
  password String
  username String @unique
  email String @unique
  pfpUrl String?
  blurb String?
  sentMessagesSolo MessagesSolo[] @relation("SentMessagesSolo")
  receivedMessagesSolo MessagesSolo[] @relation("ReceivedMessagesSolo")
  groups Groups[] @relation("groups")
  conversationsA ConversationsSolo[] @relation("userA") //must combine A and B in queries
  conversationsB ConversationsSolo[] @relation("userB")
  sender MessagesGroup[] @relation("sender")
}

model MessagesSolo {
  id Int @id @default(autoincrement())
  senderId Int
  receiverId Int
  conversationId Int
  message String
  imageUrl String?
  timeSent DateTime @default(now())
  sender Users @relation("SentMessagesSolo", fields: [senderId], references: [id])
  receiver Users @relation("ReceivedMessagesSolo", fields: [receiverId], references: [id])
  conversation ConversationsSolo @relation("messages",fields: [conversationId], references: [id])
}

model MessagesGroup {
  id Int @id @default(autoincrement())
  senderId Int
  groupId Int
  group Groups @relation(fields: [groupId], references: [id])
  sender Users @relation("sender", fields: [senderId], references: [id])
  message String
  timeSent DateTime @default(now())
  imageUrl String?
}

model Groups {
  id Int @id @default(autoincrement())
  users Users[] @relation("groups")
  messages MessagesGroup[]
  name String
}

model ConversationsSolo {
  id Int @id @default(autoincrement())
  userA Int //Limit to 2
  userB Int
  user1 Users @relation("userA", fields: [userA], references: [id])
  user2 Users @relation("userB", fields: [userB], references: [id])
  messages MessagesSolo[] @relation("messages")
}
