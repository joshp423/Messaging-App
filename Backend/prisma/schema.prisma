// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Users {
  id Int @id @default(autoincrement())
  password String
  username String
  email String @unique
  pfpUrl String?
  blurb String?
  sentMessagesSolo MessagesSolo[] @relation("SentMessagesSolo")
  receivedMessagesSolo MessagesSolo[] @relation("ReceivedMessagesSolo")
  groups Groups []
  conversations Conversations[]
  sender MessagesGroup[]
}

model MessagesSolo {
  id Int @id @default(autoincrement())
  senderId Int
  receiverId Int
  conversationId Int
  message String
  imageUrl String?
  timeSent DateTime @default(now())
  sender Users @relation("SentMessagesSolo", fields: [senderId], references: [id])
  receiver Users @relation("ReceivedMessagesSolo", fields: [receiverId], references: [id])
  conversation Conversations @relation(fields: [conversationId], references: [id])
}

model MessagesGroup {
  id Int @id @default(autoincrement())
  senderId Int
  groupId Int
  group Groups @relation(fields: [groupId], references: [id])
  sender Users @relation(fields: [senderId], references: [id])
  message String
  timeSent DateTime @default(now())
  imageUrl String?
}

model Groups {
  id Int @id @default(autoincrement())
  users Users []
  messages MessagesGroup[]
  name String
}

model Conversations {
  id Int @id @default(autoincrement())
  users Users[]
  messages MessagesSolo[]
}


