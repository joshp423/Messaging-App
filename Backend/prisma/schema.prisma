// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id Int @id @default(autoincrement())
  password String
  username String
  email String @unique
  pfpUrl String?
  blurb String?
  sentMessagesSolo MessagesSolo[] @relation("SentMessagesSolo")
  receivedMessagesSolo MessagesSolo[] @relation("ReceivedMessagesSolo")
}

model MessagesSolo {
  id Int @id @default(autoincrement())
  senderId Int
  receiverId Int
  message String
  timeSent DateTime
  sender User @relation("SentMessagesSolo", fields: [senderId], references: [id])
  receiver User @relation("ReceivedMessagesSolo", fields: [receiverId], references: [id])
}
